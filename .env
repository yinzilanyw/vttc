# ==============================
# SVMAP 统一入口环境配置（仅 single / batch）
# ==============================
# 入口模式：
# - single: 单条 query 验证（完整 pipeline + 节点输出 + metrics）
# - batch : 批量实验验证（数据集评测 + 对比统计）
# 程序不再通过命令行参数切模式，统一读取 APP_MODE。
APP_MODE=single


# ==============================
# 模型平台与鉴权（阿里云百炼 OpenAI 兼容接口）
# ==============================
# 是否启用在线模型调用。
# - 1: 在线（推荐，默认）
# - 0: 离线调试（仅用于本地排查）
USE_MODEL_API=1

# 百炼 API Key（必填；若为空且 USE_MODEL_API=1，则运行会失败）
DASHSCOPE_API_KEY=sk-0f4afae38ad5453fb41de7857972be70

# 百炼 OpenAI 兼容基地址（通常固定）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 规划器模型：负责生成任务树/DAG 与规划结构
PLANNER_MODEL=qwen3-max-2026-01-23

# 语义裁决模型：负责语义校验/判断
JUDGE_MODEL=qwen3-vl-flash-2026-01-22

# 检索代理模型：RetrieveAgent 直答检索时使用
RETRIEVE_MODEL=qwen3-vl-flash-2026-01-22


# ==============================
# 全局默认（single/batch 都可继承）
# ==============================
# 默认 task family（当 SINGLE_TASK_FAMILY 为空时生效）
# 可选：qa / summary / compare / calculate / extract / plan
DEFAULT_TASK_FAMILY=plan

# 默认 query（当 SINGLE_QUERY 为空时生效）
DEFAULT_QUERY=请设计一个 7 天研发推进计划，在 7 天内把当前的 Structured Verifiable Multi-Agent Planning with Constraint-Aware Task Trees 系统从“能生成结构正确但内容偏泛的计划”提升到“能输出主题贴合、内容具体、可验证、可触发重规划的高质量计划”。要求 Day 1 到 Day 7 逐日给出目标、具体产出和可量化验收标准，并体现递进关系，最终包含一个端到端 case study 和 ablation 实验。

# 全局失败策略（可被 SINGLE_STOP_ON_FAILURE 覆盖）
# - 1: 任一节点失败后立即终止
# - 0: 允许修复/重规划继续执行
STOP_ON_FAILURE=0

# agent 分配策略（通常保持 capability）
# - capability: 能力评分分配（推荐）
# - naive      : 简化固定分配（仅对照实验）
ASSIGNMENT_MODE=capability


# ==============================
# Single（单次验证）专用
# ==============================
# 单次运行 query。若留空，将回退到 DEFAULT_QUERY。
SINGLE_QUERY=

# 单次运行 task family。若留空，将回退到 DEFAULT_TASK_FAMILY，再由系统推断。
SINGLE_TASK_FAMILY=

# 是否导出 trace 到 artifacts/trace_*.json
SINGLE_EXPORT_TRACE=1

# 是否启用结构修复/重规划机制
SINGLE_ENABLE_REPLAN=1

# 是否启用 intent verifier
SINGLE_ENABLE_INTENT_VERIFIER=1

# 是否启用质量 verifier（需求质量/可测性/repo 绑定等）
SINGLE_ENABLE_QUALITY_VERIFIER=1

# 是否启用 plan coverage verifier（仅 plan 场景关键）
SINGLE_ENABLE_PLAN_COVERAGE_VERIFIER=1

# 单次运行失败即停（可选，留空表示沿用 STOP_ON_FAILURE）
# 可填：1 / 0 / 空
SINGLE_STOP_ON_FAILURE=

# 单次运行 agent 分配策略（可选，留空表示沿用 ASSIGNMENT_MODE）
# 可填：capability / naive / 空
SINGLE_ASSIGNMENT_MODE=

# 单次运行预算上限：最大运行步数
SINGLE_MAX_RUNTIME_STEPS=200

# 单次运行预算上限：全局最大尝试次数（节点重试累计）
SINGLE_MAX_TOTAL_ATTEMPTS=40

# 单次运行预算上限：全局最大重规划次数
SINGLE_MAX_TOTAL_REPLANS=10

# 单次运行结果保存路径（可选）
# - 为空：不额外保存（仅控制台 + trace）
# - 非空：保存一份结构化 JSON 结果
SINGLE_OUTPUT_JSON=


# ==============================
# Batch（批量实验）专用
# ==============================
# 评测数据集路径（jsonl）
BATCH_DATASET=experiments/datasets/demo_multitask.jsonl

# 批量样本数上限（从数据集头部截取）
BATCH_MAX_SAMPLES=20

# 是否保存批量产物（json + csv 到 artifacts/）
BATCH_SAVE_ARTIFACTS=1

# 批量开关：关闭 tree（no_tree 基线）
BATCH_NO_TREE=0

# 批量开关：关闭 intent verifier
BATCH_NO_INTENT=0

# 批量开关：关闭 replan（等价 no_replan）
BATCH_NO_REPLAN=0

# 批量开关：关闭 structural repair（与 no_replan 类似，更显式）
BATCH_NO_STRUCTURAL_REPAIR=0

# 批量开关：不要求 final node（实验对照用）
BATCH_NO_FINAL_NODE=0

# 批量开关：关闭 plan coverage verifier
BATCH_NO_PLAN_COVERAGE=0

# 批量开关：关闭质量 verifier（NoQualityVerifier 消融）
BATCH_NO_QUALITY_VERIFIER=0


# ==============================
# 兼容变量（可选，不建议新配置继续使用）
# ==============================
# 旧版脚本可能读取以下变量；新入口优先使用上面的 BATCH_*。
EVAL_DATASET=experiments/datasets/demo_multitask.jsonl
EVAL_MAX_SAMPLES=20
